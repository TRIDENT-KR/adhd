{
  "test_cases": [
    {
      "id": "TC001",
      "description": "Add basic routine - Simple input",
      "input": "Add a 10-minute meditation after waking up in the morning.",
      "expected": {
        "action": "add",
        "category": "Routine",
        "time_not_null": false
      }
    },
    {
      "id": "TC002",
      "description": "Add one-time appointment - Includes time",
      "input": "I have a dentist appointment tomorrow at 3 PM.",
      "expected": {
        "action": "add",
        "category": "Appointment",
        "time_not_null": true
      }
    },
    {
      "id": "TC003",
      "description": "ADHD specific - Changing mind / Mixed intents",
      "input": "Ah, today's 3 PM meeting got canceled. I'll hit the gym at 4 PM instead.",
      "expected_count": 2,
      "expected": [
        {
          "action": "delete",
          "category": "Appointment"
        },
        {
          "action": "add",
          "category": "Appointment"
        }
      ]
    },
    {
      "id": "TC004",
      "description": "ADHD specific - Changing thought mid-sentence + Rambling",
      "input": "Oh right, I need to take my meds in the evening... wait but I also need to work out... for now just add taking meds at 7 PM. And also add stretching every morning.",
      "expected_count": 2,
      "expected": [
        {
          "action": "add",
          "category": "Appointment",
          "time_contains": "07:00 PM"
        },
        {
          "action": "add",
          "category": "Routine"
        }
      ]
    },
    {
      "id": "TC005",
      "description": "English input processing",
      "input": "Add a daily morning journal at 8am",
      "expected": {
        "action": "add",
        "category": "Routine",
        "time_not_null": true
      }
    },
    {
      "id": "TC006",
      "description": "Delete request",
      "input": "Delete my workout routine.",
      "expected": {
        "action": "delete",
        "category": "Routine"
      }
    },
    {
      "id": "TC007",
      "description": "Update request",
      "input": "Change my morning meditation time from 7 AM to 6:30 AM.",
      "expected": {
        "action": "update",
        "category": "Routine",
        "time_not_null": true
      }
    },
    {
      "id": "TC008",
      "description": "Vague input - No time specified",
      "input": "I need to call my friend later.",
      "expected": {
        "action": "add",
        "category": "Appointment",
        "time_not_null": false
      }
    },
    {
      "id": "TC009",
      "description": "ADHD specific - Noise + Core intent extraction",
      "input": "Umm... what was it... oh right, I need to add a routine to drink 2 liters of water every day but kept forgetting. Please add it.",
      "expected": {
        "action": "add",
        "category": "Routine"
      }
    },
    {
      "id": "TC010",
      "description": "Complex - Simultaneous routine + appointment request",
      "input": "Add a daily run at 6 AM every morning, and also put in a team meeting at 10 AM this Friday.",
      "expected_count": 2,
      "expected": [
        {
          "action": "add",
          "category": "Routine"
        },
        {
          "action": "add",
          "category": "Appointment"
        }
      ]
    }
  ]
}
